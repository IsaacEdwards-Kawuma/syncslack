# =============================================================================
# VERCEL — Project → Settings → Environment Variables (Production + Preview)
# =============================================================================
#
#   Name   VITE_API_URL
#   Value  https://YOUR-SERVICE.onrender.com
#
# Replace YOUR-SERVICE.onrender.com with your actual Render Web Service URL
# (Dashboard → your API service → Copy the URL). No trailing slash.
#
# Example:
#   VITE_API_URL=https://sync-work-api.onrender.com
#
# After saving, redeploy Vercel (Deployments → Redeploy).
# =============================================================================

# LOCAL DEV ONLY — copy this file to .env and leave empty to use Vite proxy:
VITE_API_URL=
