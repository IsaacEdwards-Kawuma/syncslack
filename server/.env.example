PORT=5000
# Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/syncwork
# MongoDB Atlas (use your user, password, cluster host, and DB name):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/syncwork
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# Comma-separated: local dev + your Vercel app (exact URL, no path)
# RENDER: paste this same line into Environment → CLIENT_ORIGIN
CLIENT_ORIGIN=http://localhost:5173,https://syncsllack.vercel.app
NODE_ENV=development
