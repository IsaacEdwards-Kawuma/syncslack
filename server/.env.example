PORT=5000
# Neon (Dashboard → Connection string) or local Postgres:
# DATABASE_URL=postgresql://user:password@localhost:5432/syncwork
DATABASE_URL=
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
# Comma-separated: local dev + your Vercel app (exact URL, no path)
# RENDER: paste this same line into Environment → CLIENT_ORIGIN
CLIENT_ORIGIN=http://localhost:5173,https://syncsllack.vercel.app
NODE_ENV=development
